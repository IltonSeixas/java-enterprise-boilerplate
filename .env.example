# Server
SERVER_PORT=3000
GRPC_PORT=50051

# Persistence — "memory" requires no database; "postgres" requires datasource config
ADAPTER=memory

# PostgreSQL (required when ADAPTER=postgres)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/boilerplate
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password
DB_POOL_SIZE=10

# Redis (required when ADAPTER=postgres)
SPRING_DATA_REDIS_URL=redis://localhost:6379

# Authentication — HMAC-SHA256 (HS256) signing secret, minimum 32 characters
JWT_SECRET=change-me-to-a-random-value-minimum-32-characters
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Only set to true when running behind a reverse proxy that overwrites (never appends to)
# X-Forwarded-For. Otherwise the header is attacker-controlled and rate limiting per-IP
# can be trivially bypassed.
RATE_LIMIT_TRUST_FORWARDED_HEADERS=false

# Observability
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=INFO
OTEL_SAMPLING_PROBABILITY=1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
